# Image generation — either works (Gemini preferred if both set):
# Google API key for gemini-2.5-flash-image (nano banana); both the Gemini API
# and Vertex AI express endpoints are supported.
GEMINI_API_KEY=
# or Replicate token for google/nano-banana
REPLICATE_API_TOKEN=

# Set to 1 to skip generation and echo the source photo back (UI testing)
MOCK_GENERATE=0

API_PORT=8800
