# X (Twitter) OAuth 2.0 app — create at https://developer.x.com/en/portal/dashboard
# App type: Web App (confidential client). Callback URL must exactly match X_REDIRECT_URI.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8800/auth/callback

# Image generation — either works (Gemini preferred if both set):
# Google AI Studio key for gemini-2.5-flash-image (nano banana)
GEMINI_API_KEY=
# or Replicate token for google/nano-banana
REPLICATE_API_TOKEN=

# Set to 1 to skip Replicate and echo the source photo back (UI testing)
MOCK_GENERATE=0

FRONTEND_URL=http://localhost:5200
API_PORT=8800
